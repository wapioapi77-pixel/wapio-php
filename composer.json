{
    "name": "wapio/wapio",
    "description": "Official PHP / Laravel SDK for Wapio — developer-first WhatsApp API.",
    "type": "library",
    "keywords": ["wapio", "whatsapp", "whatsapp-api", "api", "sdk", "messaging", "chatbot", "laravel"],
    "homepage": "https://www.wapio.io",
    "license": "MIT",
    "authors": [
        { "name": "Wapio", "email": "support@wapio.io" }
    ],
    "support": {
        "email": "support@wapio.io",
        "docs": "https://www.wapio.io/docs"
    },
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.5",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "friendsofphp/php-cs-fixer": "^3.40"
    },
    "autoload": {
        "psr-4": {
            "Wapio\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Wapio\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Wapio\\Laravel\\WapioServiceProvider"
            ],
            "aliases": {
                "WapioApi": "Wapio\\Laravel\\Facades\\Wapio"
            }
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse --memory-limit=512M"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable"
}
